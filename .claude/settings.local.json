{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"💡 버그를 수정했나요? docs/troubleshooting.md 에 추가해 주세요! (CLAUDE.md 형식 참고)\"}'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(flutter --version)",
      "Bash(winget --version)",
      "Bash(winget install:*)",
      "Bash(winget search:*)",
      "Bash(powershell -File -)",
      "Bash(kill %1)",
      "Bash(powershell -Command \"while \\(-not \\(Test-Path 'C:\\\\\\\\flutter_sdk.zip'\\)\\) { Start-Sleep -Seconds 5; Write-Host 'waiting...' }; Write-Host 'File found!'; \\(Get-Item 'C:\\\\\\\\flutter_sdk.zip'\\).Length\")",
      "Bash(powershell -ExecutionPolicy Bypass -File \"C:\\\\\\\\Users\\\\\\\\user\\\\\\\\check_flutter.ps1\")",
      "Bash(powershell -Command \"\\(Get-Item 'C:\\\\\\\\flutter_sdk.zip'\\).Length / 1MB\")",
      "Bash(powershell -ExecutionPolicy Bypass -File \"C:\\\\\\\\Users\\\\\\\\user\\\\\\\\install_flutter.ps1\")",
      "Bash(export PATH=\"$PATH:/c/flutter/bin\")",
      "Bash(flutter create:*)",
      "Bash(flutter run:*)",
      "Bash(ollama --version)",
      "Bash(export PATH=\"$PATH:/c/Users/user/AppData/Local/Programs/Ollama\")",
      "Bash(ollama pull:*)",
      "Bash(echo \"pulling in background, PID: $!\")",
      "Bash(python -m venv .venv)",
      "Bash(py --version)",
      "Bash(powershell -Command \"python --version\")",
      "Bash(python3 -m venv .venv)",
      "Bash(.venv/Scripts/pip install:*)",
      "Bash(.venv/Scripts/uvicorn server.main:app --reload)",
      "Bash(.venv/Scripts/python -m uvicorn server.main:app --reload)",
      "Bash(curl -s -X POST http://127.0.0.1:8000/chat -H 'Content-Type: application/json' -d '{:*)",
      "Bash(curl -s -X POST http://127.0.0.1:8000/chat -H 'Content-Type: application/json' -d '{\"message\": \"오늘 점심 뭐 먹을까요? 다이어트 중입니다.\", \"user_profile\": {\"age\": 25, \"height\": 170.0, \"weight\": 70.0, \"goal\": \"다이어트\"}, \"detected_foods\": []}')",
      "Bash(powershell -Command ':*)",
      "Bash(curl -s http://127.0.0.1:8000/health)",
      "Bash(powershell -ExecutionPolicy Bypass -File \"C:\\\\\\\\Users\\\\\\\\user\\\\\\\\NutrAI\\\\\\\\test_chat.ps1\")",
      "Bash(/c/flutter/bin/flutter run:*)"
    ]
  }
}
